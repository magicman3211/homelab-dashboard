# Proxmox (comma-separated for multiple hosts)
PROXMOX_HOST=192.168.1.x
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=
PROXMOX_VERIFY_SSL=false

# Proxmox Backup Server
PBS_HOST=192.168.1.x
PBS_PORT=8007
PBS_USERNAME=root@pam
PBS_PASSWORD=
PBS_VERIFY_SSL=false

# Portainer
PORTAINER_URL=http://192.168.1.x:9000
PORTAINER_API_KEY=

# UniFi Controller
UNIFI_HOST=192.168.1.x
UNIFI_USERNAME=admin
UNIFI_PASSWORD=
UNIFI_SITE=default
UNIFI_VERIFY_SSL=false

# Refresh interval for the UI (seconds)
REFRESH_INTERVAL=60
